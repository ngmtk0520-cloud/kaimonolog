<!-- "カレンダー詳細ページ" -->
<%= render "items/header" %>

<div class=new_date>
  <h2><%= Date.parse(params[:id]).strftime("%Y年%m月%d日") %> の履歴</h2>
</div>

<main class="main-container">
  <%# 新規登録ボタン %>
  <div class="new_date">
    <%= link_to "+ 商品を追加", new_purchase_history_path(date: params[:id]), class: "btn-add" %>
  </div>

  <div class="day_date">
    <% if @calendar_events.any? %>
      <h2>
        <%= @calendar_events.first.bought_at.strftime("%Y年%m月%d日") %> の履歴
      </h2>

      <div class="history-list">
        <% @calendar_events.each do |event| %>
          <div class="date_form">
            <div class="item-name"><%= event.item_name %></div>
            <div class="price">
              <%= number_with_delimiter(event.price) %>円
              <% if event.quantity && event.quantity > 1 %>
                <small style="color: #666;"> (× <%= event.quantity %>)</small>
              <% end %>
            </div>
            
            <div class="edit-link">
              <%= link_to "編集", edit_purchase_history_path(event) %>
            </div>
            <div class="delete-link">
              <%= link_to "削除", purchase_history_path(event), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="total-price-section">
        合計 <span class="total-amount"><%= number_with_delimiter(@total_price) %>円</span>
      </div>

    <% else %>
      <h2 style="border: none;">購入履歴はありません</h2>
      <p style="text-align: center; color: #9ca3af;">右上のボタンから追加しましょう ✨</p>
    <% end %>
  </div>
</main>


<!--"フッターナビ" -->
<%= render "items/footer" %>