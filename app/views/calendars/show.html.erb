<!-- "カレンダーのトップページ" -->
<%= render "items/header" %>

<div class=new_date>
  <h2>購入履歴の新規登録</h2>
  <%= link_to "商品を追加", new_purchase_history_path %>
</div>

<div class=day_date>
  <% if @calendar_events.any? %>
    <h2><%= @calendar_events.first.bought_at.strftime("%Y年%m月%d日") %>
      購入履歴</h2>
      <% @calendar_events.each do |event| %>
        <div class="date_form", style="display: flex;flex-direction: row; justify-content: space-between; items-center">
          <div class="item-name"><%= event.item.name %></div>
          <div class="price font-bold"><%= number_with_delimiter(event.price) %>円</div>
          <div class="edit-link">
            <%= link_to "編集", edit_purchase_history_path(event) %>
          </div>
          <div class="delete-link">
            <%= link_to "削除", purchase_history_path(event), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
          </div>
        </div>
      <% end %>
    <p>合計金額: <%= number_with_delimiter(@total_price) %>円</p>
  <% else %>
    <h2>購入履歴はありません</h2>
  <% end %>
</div>


<!--"フッターナビ" -->
<%= render "items/footer" %>