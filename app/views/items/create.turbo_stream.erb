<!-- items の一覧の「先頭（prepend）」に、新しく作った _item.html.erb をリロードなしでガッチャンコします！ -->
<%= turbo_stream.prepend "#{@item.kind}_items", partial: "items/item", locals: { item: @item } %>
<%= turbo_stream.replace "form_#{@item.kind}", partial: "items/form", locals: { item: Item.new, kind: @item.kind } %>
<%= turbo_stream.update "#{@item.kind}_count", "#{@current_items_count}点" %>