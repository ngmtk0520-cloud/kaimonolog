<%# アプリヘッダー %>
<%= render "items/header" %>

<main class="main-container">

  <%# AI提案エリア %>
  <div class="ai-suggestion-container">
    <div class="ai-suggestion-list">
      <% if @ai_suggestions.present? %>
        <% @ai_suggestions.each do |item| %>
          <div class="ai-suggestion-card">
            <span class="ai-suggestion-icon">🗓️</span>
            <span class="ai-suggestion-text">
              そろそろ「<strong class="highlight-text"><%= item.name %></strong>」がなくなる時期です。
            </span>
          </div>
        <% end %>
      <% else %>
        <div class="ai-empty-message">
          <span>ストックはバッチリです ✨</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# マイカテゴリー追加エリア %>
  <div class="quick-category-form">
    <h3>マイカテゴリーを追加</h3>
      <%= form_with(model: Category.new, url: group_categories_path(@group)) do |f| %>      <%= f.text_field :name, placeholder: "例：お菓子、美容代" %>
      <%= f.submit "追加" %>
    <% end %>
  </div>

  <%# カテゴリーパネル (フォルダ選択) %>
  <div class="category-scroll-wrapper">
    <% @categories.each do |category| %>
      <div class="category-panel">
        <%= link_to items_path(category_id: category.id), 
            data: { turbo_frame: "item_list" }, 
            class: "category-card #{ 'category-card-active' if params[:category_id].to_i == category.id }" do %>
          <div class="category-card-icon">📂</div>
          <div class="category-card-title"><%= category.name %></div>
          <div class="category-card-count">
            <%= category.items.count %>点
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# メインリストエリア %>
  <div class="list-container">
    <%= turbo_frame_tag "item_list" do %>
      <%# ヘッダー部分 %>
      <h2 class="list-header">
        買い物リスト (<%= @current_kind_name || "通常購入" %>)
      </h2>

      <%# 入力エリア %>
      <div id="form_area_<%= @current_kind %>" class="list-add-section">
        <%= render "items/form", item: Item.new, kind: @current_kind, category: @current_category %>
        <div class="reset-button">
          <%= button_to "☑️リセット", bulk_update_items_path(kind: @current_kind), method: :patch %>
        </div>
      </div>

      <%# アイテム一覧エリア %>
      <div id="<%= @current_kind || 'regular' %>_items" class="list-items-wrapper">
        <% if @display_items.present? %>
          <%= render @display_items %>
        <% else %>
          <p class="list-empty-message">表示するアイテムはありません</p>
        <% end %>
      </div>
    <% end %>
  </div>
</main>

<%# スマホ用フッターナビ %>
<%= render "items/footer" %>