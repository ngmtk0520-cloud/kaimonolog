<%# アプリヘッダー %>
<%= render "items/header" %>

<main class="main-container">

  <%# AI提案エリア %>
  <div class="ai-suggestion-container">
    <div class="ai-suggestion-list">
      <% if @ai_suggestions.present? %>
        <% @ai_suggestions.each do |item| %>
          <div class="ai-suggestion-card">
            <span class="ai-suggestion-icon">🗓️</span>
            <span class="ai-suggestion-text">
              そろそろ「<strong class="highlight-text"><%= item.name %></strong>」がなくなる時期です。
            </span>
          </div>
        <% end %>
      <% else %>
        <div class="ai-empty-message">
          <span>ストックはバッチリです ✨</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# マイカテゴリー追加エリア %>
  <div class="quick-category-form">
    <h3>マイカテゴリーを追加</h3>
      <%= form_with(model: Category.new, url: group_categories_path(@group)) do |f| %>      <%= f.text_field :name, placeholder: "例：お菓子、美容代" %>
      <%= f.submit "追加" %>
    <% end %>
  </div>

  <%# カテゴリーパネル (フォルダ選択) %>
  <div class="category-scroll-wrapper">
    <% @categories.each do |category| %>
      <div class="category-panel">
        <%# activeクラスの判定をcategory_idで行う %>
        <%= link_to items_path(category_id: category.id), 
            data: { turbo_frame: "item_list" },
            class: "category-card #{ 'category-card-active' if @current_category&.id == category.id }" do %>
          <div class="category-card-icon">📂</div>
          <div class="category-card-title"><%= category.name %></div>
          <div id="category_<%= category.id %>_count" class="category-card-count">
            <%= category.items.count %>点
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# メインリストエリア %>
  <div class="list-container">
    <%= turbo_frame_tag "item_list" do %>
      <%# ヘッダー部分 %>
      <h2 class="list-header">
        買い物リスト (<%= @current_kind_name || "通常購入" %>)
      </h2>

      <%# 入力エリア %>
     <div id="item_form" class="list-add-section">
        <%= form_with(model: @item, url: items_path) do |f| %>  
          <%= f.hidden_field :category_id, value: @current_category&.id %>

          <%= f.text_field :name, placeholder: "商品名を入力", required: true %>

          <div class="form-check">
            <%= f.check_box :kind, { class: "form-check-input" }, "subscription", "regular" %>
            <%= f.label :kind, "このアイテムの買い時を予測する", class: "form-check-label" %>
          </div>

          <%# 💥 リセットボタンはフォームの外、または別のdivに分ける %>
          <%= f.submit "追加", class: "submit-button" %>
        <% end %>

        <%# 一括りセットボタン %>
        <div class="reset-button-area">
          <%= button_to "☑️一括リセット", bulk_update_items_path(category_id: @current_category&.id), method: :patch, class: "reset-btn" %>
        </div>
      </div>
        
      <%# アイテム一覧エリア %>
      <%= turbo_frame_tag "item_list" do %>
        <div id="category_<%= @current_category&.id %>_items" class="list-items-wrapper">
          <% if @items.present? %>
            <%= render @items %>
          <% else %>
            <p class="list-empty-message">このカテゴリーにアイテムはありません</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</main>

<%# スマホ用フッターナビ %>
<%= render "items/footer" %>