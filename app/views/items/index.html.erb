<%# アプリヘッダー %>
<header class="app-header">
  <h1>
    <%= link_to image_tag("kaimonolog.png", alt: "Kaimonolog", class: "header-logo"), root_path(@item) %>
  </h1>
  <%# ユーザーウェルカムエリア %>
  <div class="welcome-container">
    <p class="welcome-text">
      <p class="greeting">こんにちは</p>
      <span class="user-name"><%= current_user.nickname %></span>さん！
    </p>
  </div>

</header>

<main class="main-container">

  <%# AI提案エリア %>
  <div class="ai-suggestion-container">
    <div class="ai-suggestion-list">
      <% if @ai_suggestions.present? %>
        <% @ai_suggestions.each do |item| %>
          <div class="ai-suggestion-card">
            <span class="ai-suggestion-icon">🗓️</span>
            <span class="ai-suggestion-text">
              そろそろ「<strong class="highlight-text"><%= item.name %></strong>」がなくなる時期です。
            </span>
          </div>
        <% end %>
      <% else %>
        <div class="ai-empty-message">
          <span>ストックはバッチリです ✨</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# カテゴリーパネル (フォルダ選択) %>
  <div class="category-scroll-wrapper">
    <% [
      { kind: "regular",      name: "通常購入",    emoji: "🛒", items: @regular_items },
      { kind: "subscription", name: "定期購入",    emoji: "🗓️", items: @subscription_items },
      { kind: "spot",         name: "スポット購入", emoji: "📍", items: @spot_items }
    ].each do |panel| %>
      
      <%= link_to items_path(kind: panel[:kind]), 
          data: { turbo_frame: "item_list" }, 
          class: "category-card #{ 'category-card-active' if @current_kind == panel[:kind] }" do %>
        <div class="category-card-icon"><%= panel[:emoji] %></div>
        <div class="category-card-title"><%= panel[:name] %></div>
        <div class="category-card-count"><%= panel[:items].count %>点</div>
      <% end %>

    <% end %>
  </div>

  <%# メインリストエリア %>
  <div class="list-container">
    <%= turbo_frame_tag "item_list" do %>
      <%# ヘッダー部分 %>
      <h2 class="list-header">
        買い物リスト (<%= @current_kind_name || "通常購入" %>)
      </h2>

      <%# 入力エリア %>
      <div class="list-add-section">
        <%= render "items/form", item: Item.new, kind: @current_kind || "regular", category: @current_category %>
      </div>

      <%# アイテム一覧エリア %>
      <div class="list-items-wrapper">
        <% if @display_items.present? %>
          <%= render @display_items %>
        <% else %>
          <p class="list-empty-message">表示するアイテムはありません</p>
        <% end %>
      </div>
    <% end %>
  </div>
</main>

<%# スマホ用フッターナビ %>
<footer class="footer-nav">
  <a href="<%= items_path%>" class="nav-item <%= current_page?(items_path) ? 'nav-item-active' : '' %>">
    <div class="text-xl">🏠</div>
    <div class="text-[10px] font-bold">ホーム</div>
  </a>
  <a href="#" class="nav-item">
    <div class="text-xl">📅</div>
    <div class="text-[10px] font-bold">予定</div>
  </a>
  <a href="#" class="nav-item">
    <div class="text-xl">📊</div>
    <div class="text-[10px] font-bold">収支表</div>
  </a>
  <a href="#" class="nav-item">
    <div class="text-xl">⚙️</div>
    <div class="text-[10px] font-bold">設定</div>
  </a>
</footer>