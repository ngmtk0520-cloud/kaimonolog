<h1>🛒 買い物リスト</h1>

<!-- 1. 新しい商品を追加するフォーム -->
<%= form_with model: @item, url: items_path do |f| %>
  <%= f.text_field :name, placeholder: "買うものを入力", required: true %>
  <!-- 💥 カテゴリー選択を追加 -->
  <%= f.collection_select :category_id, @group.categories, :id, :name, { include_blank: "カテゴリーなし" } %>
  <%= f.submit "追加" %>
<% end %>

<hr>

<!-- 2. 💥 ここがHotwireのポイント！ -->
<!-- id="items" の中に、追加したアイテムがリロードなしで差し込まれます -->
<div id="items">
  <%= render @items %>
</div>