<div id="item_<%= item.id %>" style="display: flex; align-items: center; justify-content: space-between; padding: 10px; border-bottom: 1px solid #ddd;">
  <div style="display: flex; align-items: center;">
    
    <%# 💥 すでにリストにあるアイテムを「更新」するためのフォーム %>
    <%= form_with model: item, url: item_path(item), method: :patch, data: { turbo_stream: true } do |f| %>
      <%# 💥 チェックした瞬間に送信！ %>
      <%= f.check_box :is_checked, onchange: "this.form.requestSubmit()" %>
      <%# 💥 金額入力欄を追加。未入力でもOKにする %>
      <%= f.number_field :price, placeholder: "￥", style: "width: 60px; font-size: 10px;" %>
    <% end %>

    <span style="margin-left: 10px; <%= 'text-decoration: line-through; color: gray;' if item.is_checked %>">
      <%= item.name %>
    </span>
  </div>

  <%# 削除ボタン %>
  <%= button_to "🗑️", item_path(item), method: :delete, data: { turbo_method: :delete, turbo_confirm: "削除しますか？" }, style: "background: none; border: none; cursor: pointer;" %>
</div>