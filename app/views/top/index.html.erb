<header class="app-header">
  <h1>
    <%= link_to root_path do %>
      <%= image_tag "kaimonolog.png", alt: "Kaimonolog", class: "header-logo" %>
    <% end %>
  </h1>
</header>

<main class="main-container">
  <% if user_signed_in? %>
    <div class="user-info">
      <p>こんにちは、<strong><%= current_user.nickname %></strong> さん！</p>
      <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn-outline" %>
    </div>

    <% if current_user.group_id.nil? %>
      <div class="welcome-message">
        <h2>グループに参加していません</h2>
        <p>買い物リストを共有するために、新しく作るか招待コードを入力してください。</p>
      </div>

      <div class="group-actions">
        <!-- グループ新規作成 -->
        <div class="group-card">
          <h3>新しくグループを作る</h3>
          <%= form_with model: Group.new, url: groups_path do |f| %>
            <%= f.text_field :name, placeholder: "グループ名を入力" %>
            <%= f.submit "作成する", class: "btn-primary" %>
          <% end %>
        </div>

        <!-- 招待コード参加 -->
        <div class="group-card">
          <h3>招待コードで参加</h3>
          <%= form_with url: join_groups_path, method: :post do |f| %>
            <%= f.text_field :invite_token, placeholder: "招待コードを入力" %>
            <%= f.submit "参加する", class: "btn-primary" %>
          <% end %>
        </div>
      </div>

    <% else %>
      <div class="group-card" >
        <h2>所属：<%= current_user.group.name %></h2>
        <p><%= link_to "🛒 買い物リストを見る", items_path, class: "btn-primary" %></p>
      </div>
    <% end %>

  <% else %>
    <div class="group-card" >
      <p>ご利用にはログインが必要です</p>
      <div style="margin-top: 20px; display: flex; gap: 10px;">
        <%= link_to "ログイン", new_user_session_path, class: "btn-primary" %>
        <%= link_to "新規登録", new_user_registration_path, class: "btn-primary", style: "background-color: #28a745;" %>
      </div>
    </div>
  <% end %>
</main>