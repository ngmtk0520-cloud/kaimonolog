<%= render "items/header" %>

<div class="main-container">
  <h2 class=setting-name>設定</h2>

  <%# プロフィールセクション %>
  <div class="content">
    <div class="content-box">
      <p class="content-name">プロフィール</p>
      <%= link_to "編集", edit_user_registration_path, class: "profile-edit-link" %>
    </div>
  </div>

  <%# グループセクション %>
  <div class="content">
    <div class="content-box">
      <p class="content-name">グループ</p>
      <%# グループ名編集へのリンク（実装済みのパスに合わせて調整してください） %>
      <%= link_to "編集", edit_group_path(current_user.group), class: "group-edit-link" %>
    </div>
    <p class="text-xl font-bold border-b pb-2 mb-4"><%= current_user.group.name %></p>
    
    <p class="content-name">招待コード（共有用）</p>
    <div class="invite-token-box">
      <code id="invite-token" class="invite-token-code"><%= current_user.group.invite_token %></code>
      <button onclick="copyInviteToken()" class="copy-button">
        コピー
      </button>
    </div>
    <p id="copy-message" class="copy-message"></p> <%# コピー完了メッセージ用 %>
  </div>

  <%# アプリ設定セクション %>
  <div class="content-box">
    <p class="content-name">カテゴリー</p>
    <%= link_to "編集", categories_path, class: "content-edit-link" %>
  </div>

  <%# 危険な操作セクション %>
  <div class="danger-zone">
    
    <div class="logout-box">
      <%= link_to destroy_user_session_path, 
                  data: { turbo_method: :delete, turbo_confirm: "ログアウトしてもよろしいですか？" }, 
                  class: "logout-link" do %>
        ログアウト
      <% end %>
    </div>
  </div>
</div>

<%# シンプルなコピー用JavaScript %>
<script>
function copyInviteToken() {
  const token = document.getElementById('invite-token').innerText;
  navigator.clipboard.writeText(token).then(() => {
    const msg = document.getElementById('copy-message');
    msg.innerText = "コピーしました！";
    setTimeout(() => msg.innerText = "", 2000);
  });
}
</script>

<%= render "items/footer" %>