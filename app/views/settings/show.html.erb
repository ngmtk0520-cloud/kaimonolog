<%= render "items/header" %>

<div class="settings-page p-6 pb-32 max-w-md mx-auto">
  <h2 class="text-2xl font-bold mb-8 text-gray-800">設定</h2>

  <%# プロフィールセクション %>
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <div class="flex justify-between items-center mb-1">
      <p class="text-sm text-gray-500">プロフィール</p>
      <%= link_to "編集", edit_user_registration_path, class: "text-xs text-blue-500" %>
    </div>
    <p class="text-xl font-bold"><%= current_user.nickname %> <span class="text-sm font-normal text-gray-400">さん</span></p>
  </div>

  <%# グループセクション %>
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <div class="flex justify-between items-center mb-1">
      <p class="text-sm text-gray-500">現在のグループ</p>
      <%# グループ名編集へのリンク（実装済みのパスに合わせて調整してください） %>
      <%= link_to "名前変更", edit_group_path(current_user.group), class: "text-xs text-blue-500" %>
    </div>
    <p class="text-xl font-bold border-b pb-2 mb-4"><%= current_user.group.name %></p>
    
    <p class="text-sm text-gray-500 mb-1">招待コード（共有用）</p>
    <div class="flex items-center justify-between bg-gray-100 p-3 rounded">
      <code id="invite-token" class="text-blue-600 font-mono font-bold text-lg"><%= current_user.group.invite_token %></code>
      <button onclick="copyInviteToken()" class="bg-blue-500 hover:bg-blue-600 text-white text-xs px-3 py-2 rounded-full shadow-sm transition-all active:scale-95">
        コピー
      </button>
    </div>
    <p id="copy-message" class="text-xs text-green-500 mt-1 h-4"></p> <%# コピー完了メッセージ用 %>
  </div>

  <%# アプリ設定セクション %>
  <div class="bg-white rounded-lg shadow mb-6 overflow-hidden">
    <%= link_to categories_path, class: "flex items-center justify-between p-4 hover:bg-gray-50 border-b" do %>
      <span class="text-gray-700">🏷️ カテゴリーの管理</span>
      <span class="text-gray-400">＞</span>
    <% end %>
  </div>

  <%# 危険な操作セクション %>
  <div class="mt-12 flex flex-col space-y-4 text-center">
    <%= link_to leave_groups_path, 
                data: { turbo_method: :patch, turbo_confirm: "グループを抜けると履歴が見られなくなります。本当によろしいですか？" }, 
                class: "text-red-500 font-bold py-2" do %>
      🚪 グループを抜ける
    <% end %>
    
    <div class="border-t pt-4">
      <%= link_to destroy_user_session_path, 
                  data: { turbo_method: :delete, turbo_confirm: "ログアウトしてもよろしいですか？" }, 
                  class: "text-gray-400 text-sm" do %>
        ログアウト
      <% end %>
    </div>
  </div>
</div>

<%# シンプルなコピー用JavaScript %>
<script>
function copyInviteToken() {
  const token = document.getElementById('invite-token').innerText;
  navigator.clipboard.writeText(token).then(() => {
    const msg = document.getElementById('copy-message');
    msg.innerText = "コピーしました！";
    setTimeout(() => msg.innerText = "", 2000);
  });
}
</script>

<%= render "items/footer" %>