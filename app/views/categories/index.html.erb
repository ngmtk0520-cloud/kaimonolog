<%= render "items/header" %>

<main class="main-container">
  <div class="welcome-message">
    <h2>カテゴリー管理</h2>
    <p>リストの整理や名前の変更ができます。</p>
  </div>

  <div class="group-card">
    <div class="category-list">
      <% @categories.each do |category| %>
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #eee;">
          <div style="font-weight: bold; color: #333;">
            <%= category.name %>
          </div>
          
          <div style="display: flex; gap: 12px;">
            <%= link_to "編集", edit_category_path(category), style: "color: #007bff; font-size: 0.85rem; text-decoration: none;" %>
            
            <%# 「定期購入」は削除ボタンを出さない %>
            <% unless category.name == "定期購入" %>
              <%= link_to "削除", category_path(category), 
                          data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？\nこのカテゴリーのアイテムもすべて削除されます。" }, 
                          style: "color: #dc3545; font-size: 0.85rem; text-decoration: none;" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div style="margin-top: 25px; text-align: center;">
      <%= link_to "← 設定に戻る", settings_path, style: "color: #888; font-size: 0.9rem; text-decoration: none;" %>
    </div>
  </div>
</main>

<%= render "items/footer" %>